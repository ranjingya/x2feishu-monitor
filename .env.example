# X Developer App 的 App-Only Bearer Token
X_BEARER_TOKEN=请填写_Bearer_Token

# 目标用户的数字 ID 和不带 @ 的用户名
X_USER_ID=请填写用户ID
X_USERNAME=请填写用户名

# 飞书群自定义机器人的 V2 Webhook 与安全关键词
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/请填写Webhook
FEISHU_KEYWORD=X 更新

# 默认每 5 分钟轮询一次
POLL_INTERVAL_SECONDS=300
REQUEST_TIMEOUT_SECONDS=20

# 默认只监听原创帖子
X_INCLUDE_REPLIES=false
X_INCLUDE_RETWEETS=false

# 每页和每轮最大读取量
X_MAX_RESULTS=100
X_MAX_PAGES_PER_POLL=10

# 留空时首次启动自动使用当时最新帖子作为基线
INITIAL_SINCE_ID=

# 容器内持久化数据库位置
STATE_DB_PATH=/data/state.db

# 消息与日志设置
FEISHU_MESSAGE_MAX_LENGTH=19000
DISPLAY_UTC_OFFSET=+08:00
LOG_LEVEL=INFO

# 可选：通过 OpenAI 兼容的 Chat Completions 接口生成译文
TRANSLATION_ENABLED=false
TRANSLATION_API_URL=https://请填写翻译服务地址/v1/chat/completions
TRANSLATION_API_KEY=
TRANSLATION_MODEL=请填写模型名称
TRANSLATION_TARGET_LANGUAGE=简体中文
TRANSLATION_TIMEOUT_SECONDS=30
